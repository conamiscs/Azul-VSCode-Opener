<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<External>null</External>
	<External>nil</External>
	<Item class="Script" referent="RBX160802AECE7D495E82DB318880314ED3">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local toolbar = plugin:CreateToolbar("VSCode opener")
local StudioService = game:GetService("StudioService")
local HttpService = game:GetService("HttpService")
local ScriptEditorService = game:GetService("ScriptEditorService")

local button = toolbar:CreateButton(
	"Toggle",
	"toggles whether or not you want vscode to automatically open when you select a script",
	""
)

local widgetinfo = DockWidgetPluginGuiInfo.new(
	Enum.InitialDockState.Float,
	false,
	false,
	500,
	300,
	100,
	100
)

local widget = plugin:CreateDockWidgetPluginGuiAsync("VSCode Opener", widgetinfo)

local gui = script.Frame:Clone()
gui.Parent = widget
gui.Size = UDim2.fromScale(1,1)

local enabled = false

local lastscript = nil

local port = 8880

gui.TextButton.MouseButton1Click:Connect(function()
	enabled = not enabled
	if enabled == true then
		port = gui.TextBox.Text
		gui.TextButton.Text = "Enabled: On"
	else
		gui.TextButton.Text = "Enabled: Off"
	end
end)



StudioService:GetPropertyChangedSignal("ActiveScript"):Connect(function()
	if enabled == true then
		local active = StudioService.ActiveScript

		if active and active ~= lastscript then
			lastscript = active
			local scripttype = "ModuleScript"
			
			if active:IsA("ModuleScript") then
				scripttype = "ModuleScript"
			elseif active:IsA("Script") then
				scripttype = "Script"
			elseif active:IsA("LocalScript") then
				scripttype = "LocalScript"
			end
			
			local data = HttpService:JSONEncode({
				path = active:GetFullName(),
				scripttype = scripttype
			})
			print("Script opened! "..active:GetFullName())
			local success, err = pcall(function()
				HttpService:PostAsync(`http://localhost:{port}/open`,data,Enum.HttpContentType.ApplicationJson)

				for _,document in pairs(ScriptEditorService:GetScriptDocuments()) do
					if document:GetScript() == active then
						document:CloseAsync()
						break
					end
				end
			end)
			if not success then
				warn("Error sending script to VSCode "..err)
			end
		end
	end
end)

button.Click:Connect(function()
	--enabled = not enabled
	--if enabled == true then
	--	warn("Plugin Enabled!")
	--else
	--	warn("Plugin Disabled!")
	--end
	widget.Enabled = not widget.Enabled
	
end)]]></ProtectedString>
